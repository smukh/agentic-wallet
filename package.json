{
  "name": "agentic-wallet",
  "version": "1.0.0",
  "description": "CLI for agents to create and manage MoonPay local wallets for ERC-8004 and x402 payments",
  "main": "dist/index.js",
  "bin": {
    "agent-wallet": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wallet",
    "agent",
    "erc8004",
    "x402",
    "crypto",
    "ethereum",
    "base",
    "ai-agent"
  ],
  "author": "Agent Arena",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-arena/wallet-cli"
  },
  "homepage": "https://agentarena.site",
  "bugs": {
    "url": "https://github.com/agent-arena/wallet-cli/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^13.3.2",
    "ora": "^8.1.0",
    "uuid": "^10.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
