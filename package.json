  "bugs": {
    "url": "https://github.com/smukh/agentic-wallet/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^13.3.2",
    "ora": "^8.1.0",
    "uuid": "^10.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
